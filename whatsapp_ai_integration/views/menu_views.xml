<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_whatsapp_dashboard" model="ir.actions.client">
        <field name="name">Dashboard</field>
        <field name="tag">whatsapp_ai_dashboard</field>
    </record>
    <record id="action_whatsapp_conversation" model="ir.actions.act_window">
        <field name="name">Conversations</field>
        <field name="res_model">whatsapp.conversation</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="whatsapp_conversation_view_search"/>
        <field name="context">{'search_default_active': 1}</field>
    </record>
    <record id="action_whatsapp_message" model="ir.actions.act_window">
        <field name="name">Messages</field>
        <field name="res_model">whatsapp.message</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="whatsapp_message_view_search"/>
    </record>
    <record id="action_whatsapp_message_failed" model="ir.actions.act_window">
        <field name="name">Failed Messages</field>
        <field name="res_model">whatsapp.message</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('state','=','failed')]</field>
    </record>
    <record id="action_whatsapp_compose_wizard" model="ir.actions.act_window">
        <field name="name">Send WhatsApp Message</field>
        <field name="res_model">whatsapp.compose.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_whatsapp_root" name="WhatsApp AI" web_icon="whatsapp_ai_integration,static/description/icon.png" sequence="75"/>
    <menuitem id="menu_whatsapp_dashboard" name="Dashboard" parent="menu_whatsapp_root" action="action_whatsapp_dashboard" sequence="1"/>
    <menuitem id="menu_whatsapp_conversations" name="Conversations" parent="menu_whatsapp_root" action="action_whatsapp_conversation" sequence="10"/>
    <menuitem id="menu_whatsapp_messages_parent" name="Messages" parent="menu_whatsapp_root" sequence="20"/>
    <menuitem id="menu_whatsapp_messages_all" name="All Messages" parent="menu_whatsapp_messages_parent" action="action_whatsapp_message" sequence="1"/>
    <menuitem id="menu_whatsapp_messages_failed" name="Failed Messages" parent="menu_whatsapp_messages_parent" action="action_whatsapp_message_failed" sequence="2"/>
    <menuitem id="menu_whatsapp_actions_parent" name="Quick Actions" parent="menu_whatsapp_root" sequence="30"/>
    <menuitem id="menu_whatsapp_compose" name="Send Message" parent="menu_whatsapp_actions_parent" action="action_whatsapp_compose_wizard" sequence="1"/>
    <menuitem id="menu_whatsapp_config_parent" name="Configuration" parent="menu_whatsapp_root" sequence="99" groups="base.group_system"/>
    <menuitem id="menu_whatsapp_config_settings" name="Settings" parent="menu_whatsapp_config_parent" action="base.action_general_configuration" sequence="1"/>
</odoo>
