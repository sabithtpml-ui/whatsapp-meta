<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="whatsapp_conversation_view_tree" model="ir.ui.view">
        <field name="name">whatsapp.conversation.tree</field>
        <field name="model">whatsapp.conversation</field>
        <field name="arch" type="xml">
            <tree string="Conversations" default_order="last_message_date desc" decoration-info="state=='ai_handled'" decoration-warning="state=='human_takeover'" decoration-muted="state=='closed'">
                <field name="display_name" string="Contact"/>
                <field name="phone"/>
                <field name="partner_id"/>
                <field name="message_count" string="Messages"/>
                <field name="last_message_body" string="Last Message"/>
                <field name="last_message_date"/>
                <field name="state"/>
                <field name="assigned_user_id"/>
            </tree>
        </field>
    </record>
    <record id="whatsapp_conversation_view_kanban" model="ir.ui.view">
        <field name="name">whatsapp.conversation.kanban</field>
        <field name="model">whatsapp.conversation</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" quick_create="false">
                <field name="display_name"/>
                <field name="phone"/>
                <field name="state"/>
                <field name="message_count"/>
                <field name="last_message_body"/>
                <field name="last_message_date"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <strong><field name="display_name"/></strong>
                                <div class="text-muted"><i class="fa fa-phone"/> <field name="phone"/></div>
                                <div class="text-muted mt-1" style="font-size:0.85em;"><field name="last_message_body"/></div>
                                <div class="mt-2">
                                    <span class="badge rounded-pill bg-secondary"><i class="fa fa-comments"/> <field name="message_count"/></span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <record id="whatsapp_conversation_view_form" model="ir.ui.view">
        <field name="name">whatsapp.conversation.form</field>
        <field name="model">whatsapp.conversation</field>
        <field name="arch" type="xml">
            <form string="WhatsApp Conversation">
                <header>
                    <button name="action_human_takeover" string="Take Over" type="object" class="btn-primary" attrs="{'invisible': [('state','in',['human_takeover','closed'])]}"/>
                    <button name="action_resume_ai" string="Resume AI" type="object" class="btn-secondary" attrs="{'invisible': [('state','!=','human_takeover')]}"/>
                    <button name="action_close" string="Close" type="object" class="btn-secondary" attrs="{'invisible': [('state','=','closed')]}"/>
                    <field name="state" widget="statusbar" statusbar_visible="new,active,ai_handled,human_takeover,closed"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="display_name" readonly="1"/></h1></div>
                    <group>
                        <group string="Contact">
                            <field name="partner_id"/>
                            <field name="phone"/>
                            <field name="assigned_user_id"/>
                        </group>
                        <group string="Activity">
                            <field name="message_count"/>
                            <field name="last_message_date"/>
                            <field name="channel_id"/>
                        </group>
                    </group>
                    <group string="Quick Reply" attrs="{'invisible': [('state','=','closed')]}">
                        <button name="%(whatsapp_ai_integration.action_whatsapp_compose_wizard)d" string="Send Message" type="action" class="btn-primary" context="{'default_partner_id': partner_id, 'default_phone': phone}"/>
                    </group>
                    <notebook>
                        <page string="Messages" name="messages">
                            <field name="message_ids" nolabel="1" readonly="1">
                                <tree default_order="create_date asc" decoration-info="direction=='incoming'" decoration-success="direction=='outgoing'">
                                    <field name="create_date" string="Time"/>
                                    <field name="direction"/>
                                    <field name="body"/>
                                    <field name="state"/>
                                    <field name="is_chatbot" string="AI"/>
                                </tree>
                            </field>
                        </page>
                        <page string="AI Context" name="ai_context">
                            <field name="ai_context"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
    <record id="whatsapp_conversation_view_search" model="ir.ui.view">
        <field name="name">whatsapp.conversation.search</field>
        <field name="model">whatsapp.conversation</field>
        <field name="arch" type="xml">
            <search string="Search Conversations">
                <field name="display_name"/>
                <field name="phone"/>
                <field name="partner_id"/>
                <separator/>
                <filter string="Active" name="active" domain="[('state','in',['active','ai_handled','new'])]"/>
                <filter string="Human" name="human" domain="[('state','=','human_takeover')]"/>
                <filter string="AI" name="ai" domain="[('state','=','ai_handled')]"/>
                <filter string="Closed" name="closed" domain="[('state','=','closed')]"/>
                <separator/>
                <filter string="Mine" name="mine" domain="[('assigned_user_id','=',uid)]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_state" context="{'group_by':'state'}"/>
                    <filter string="Contact" name="group_partner" context="{'group_by':'partner_id'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
