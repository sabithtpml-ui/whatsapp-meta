<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="mail_template_wa_new_message" model="mail.template">
            <field name="name">WhatsApp: New Message Notification</field>
            <field name="model_id" ref="model_whatsapp_conversation"/>
            <field name="subject">New WhatsApp message from {{ object.display_name }}</field>
            <field name="body_html"><![CDATA[
<p>Hello,</p>
<p>A new WhatsApp message was received from <strong>{{ object.display_name }}</strong> ({{ object.phone }}).</p>
<p><em>"{{ object.last_message_body }}"</em></p>
]]></field>
            <field name="auto_delete" eval="True"/>
        </record>
    </data>
</odoo>
